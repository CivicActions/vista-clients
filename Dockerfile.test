# Dockerfile.test — Verify library runs in a minimal Alpine container (SC-003)
FROM python:3.10-alpine

WORKDIR /app

# Copy only what's needed
COPY pyproject.toml .
COPY src/ src/
COPY tests/unit/ tests/unit/
COPY tests/contract/ tests/contract/

# Install the package and test dependencies
RUN pip install --no-cache-dir . pytest

# Run unit and contract tests only (no smoke tests — no VEHU access)
CMD ["pytest", "tests/unit/", "tests/contract/", "-v", "--tb=short"]
